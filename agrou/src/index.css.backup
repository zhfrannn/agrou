@import "tailwindcss";

/* ── Design Tokens ── */
@theme {
  --font-sans: "Plus Jakarta Sans", ui-sans-serif, system-ui, -apple-system, sans-serif;
  --font-display: "Archivo Black", ui-sans-serif, system-ui, sans-serif;
  --font-serif: "Archivo Black", ui-sans-serif, system-ui, sans-serif;
}

/* ── Global Font — Plus Jakarta Sans for all body text ── */
*,
*::before,
*::after {
  font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  letter-spacing: 0em;
}

/* ── Display headings — Archivo Black: bold, condensed, assertive ── */
h1,
h2,
h3,
.font-display,
[class*="font-display"],
.font-serif,
[class*="font-serif"] {
  font-family: "Archivo Black", ui-sans-serif, system-ui, sans-serif;
  font-weight: 400 !important; /* Archivo Black is inherently black-weight */
  letter-spacing: -0.02em !important;
  line-height: 1.1 !important;
}

/* ── Body Background — cream warm editorial ── */
body {
  background-color: var(--color-cream);
  color: var(--color-text-primary);
  line-height: 1.6;
}

/* ── Colour palette tokens ── */
:root {
  /* Forest greens — deep, vivid, bold */
  --color-forest:       #0F3D2E;
  --color-forest-dark:  #0A2B20;

  /* Lime — neon accent for badges, highlights, energetic CTAs */
  --color-lime:         #C5F23D;
  --color-lime-dark:    #9FCB1F;

  /* Warm cream surfaces */
  --color-cream:        #F7F3E7;

  /* Card surface — white pops above cream */
  --color-surface:      #FFFFFF;

  /* Accent orange — CTA, price, urgency */
  --color-accent:       #F77F00;
  --color-accent-dark:  #C75F00;

  /* Text */
  --color-text-primary:    #16231E;
  --color-text-on-dark:    #F7F3E7;
  --color-text-secondary:  #5B6B65;

  /* Border */
  --color-border:       #E2DFC9;
}

/* ── Global card radius softener — override Tailwind inline rounded utils ──
   This makes every rounded-2xl/3xl slightly softer without touching JSX */
.rounded-2xl {
  border-radius: 18px !important;
}

.rounded-3xl {
  border-radius: 24px !important;
}

.rounded-xl {
  border-radius: 14px !important;
}

.rounded-lg {
  border-radius: 10px !important;
}

/* ── Shadow system — vivid, bold depth ── */
.shadow-md {
  box-shadow: 0 2px 12px rgba(15, 61, 46, 0.12) !important;
}

.shadow-lg {
  box-shadow: 0 4px 24px rgba(15, 61, 46, 0.15) !important;
}

.shadow-xl {
  box-shadow: 0 8px 36px rgba(15, 61, 46, 0.18) !important;
}

.shadow-2xl {
  box-shadow: 0 16px 56px rgba(15, 61, 46, 0.22) !important;
}

/* ── Scrollbar styling — minimal, on-brand ── */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(15, 61, 46, 0.22);
  border-radius: 99px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(15, 61, 46, 0.40);
}

/* ── Hide scrollbar utility ── */
.scrollbar-hide::-webkit-scrollbar {
  display: none;
}

.scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* ── Selection color — lime on forest ── */
::selection {
  background: var(--color-lime);
  color: var(--color-forest-dark);
}

/* ── Global link style ── */
a {
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
}